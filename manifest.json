{
  "manifest_version": 3,
  "name": "Baixar fotos do Facebook",
  "version": "0.2",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "tabs",
    "scripting",
    "downloads"
  ],

  "host_permissions": [
    "https://docs.google.com/*",
    "https://*.facebook.com/*"
  ]
}